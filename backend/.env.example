# Copy this file to `.env` locally; on Railway set the same keys under
# Service → Variables. Never commit the real .env.

# ── Supabase (required) ─────────────────────────────────────────
# Project URL + anon/publishable key. RLS enforces per-user access
# using the JWT from the frontend; no service_role key needed here.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# ── AI providers (required) ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Frontend URL (required) ─────────────────────────────────────
# The FastAPI CORS middleware allows exactly this origin (plus
# http://localhost:3000 for dev). On Railway set this to your
# frontend service's public domain, e.g.
#   FRONTEND_URL=https://mies-frontend-production.up.railway.app
FRONTEND_URL=http://localhost:3000

# ── Indexer credentials (optional) ──────────────────────────────
# Used only by `scripts/index_*` when you run chunking jobs locally
# against the production database. Not needed at runtime — Railway
# does not need these to serve chat.
INDEXER_EMAIL=
INDEXER_PASSWORD=
